{
  // tasks.json版本号
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "build",
      "command": "make",
      "args": [
        "-j",
        "16"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "shell",
      "label": "clean",
      "command": "make",
      "args": [
        "clean"
      ],
      "problemMatcher": [
        "$gcc"
      ],
      "group": "build"
    },
    {
      "label": "rebuild",
      "dependsOn": [
        "clean",
        "build"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": [],
      "group": "build"
    },
    {
      "type": "shell",
      "label": "download",
      "command": "openocd",
      "args": [
        "-f",
        "./Tools/interface/jlink.cfg",
        "-f",
        "./Tools/target/stm32f4x.cfg",
        "-c",
        "program ./build/helloworld.elf verify reset exit"
      ],
      "dependsOn": "build",
      "problemMatcher": [],
      "group": "build"
    }
  ]
}
